# Pulse API (Sanctum)
VITE_API_BASE_URL=https://pulse.appp-psy.ru/api/v1

# Laravel Reverb (Echo / Pusher protocol) — как в apps/pulse-mobile
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=pulse.appp-psy.ru
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ACHPP ID (Passport public client + PKCE)
# Продовый IdP: id.appp-psy.ru
VITE_ACHPP_ID_BASE_URL=https://id.appp-psy.ru
VITE_ACHPP_ID_CLIENT_ID=c6000000-0000-4000-8000-000000000001
# VITE_ACHPP_ID_SCOPE=*

# Desktop: зарегистрируйте в клиенте IdP redirect URI точно:
# pulse-desktop://auth/callback
