{
  "name": "pulse-desktop",
  "version": "1.0.5",
  "main": "dist-electron/main/index.js",
  "description": "Pulse — десктоп-клиент центра обращений АЧПП (мессенджер для модераторов).",
  "author": "Eugene @prod-broke-again",
  "license": "MIT",
  "private": true,
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue"
  ],
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "type": "module",
  "scripts": {
    "predev": "node ./scripts/sync-public-logo.mjs",
    "prebuild": "node ./scripts/sync-public-logo.mjs && node ./scripts/ensure-electron-local.mjs",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "cap:sync": "vite build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "29.4.6",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.6"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "laravel-echo": "^2.3.4",
    "lucide-vue-next": "^0.564.0",
    "pinia": "^3.0.4",
    "electron-updater": "^6.3.9",
    "pusher-js": "^8.5.0",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.1.18"
  }
}
