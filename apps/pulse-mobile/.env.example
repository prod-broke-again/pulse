# Public frontend variables only (Vite embeds these into build output).
# DO NOT put secrets here.

# API
VITE_API_BASE_URL=https://pulse.test/api/v1
VITE_API_ORIGIN=https://pulse.test
# Axios timeout ms (default 90000). SSO + slow IdP needs headroom.
# VITE_HTTP_TIMEOUT_MS=90000

# Auth: require Sanctum token for all routes except login/callback (set true for real API usage)
# VITE_REQUIRE_AUTH=false

# ACHPP ID — public OAuth client (Passport) with PKCE; redirect URI must match IdP client
VITE_ACHPP_ID_BASE_URL=https://id.test
# Local IdP Passport client (OAuthPulseMobileClientSeeder): c6000000-0000-4000-8000-000000000001
VITE_ACHPP_ID_CLIENT_ID=c6000000-0000-4000-8000-000000000001
# Web: localhost uses http://localhost:5174/auth/callback automatically; set this for staging/prod web
# VITE_ACHPP_ID_REDIRECT_URI=https://pulse.test/auth/callback
# Native: pulseapp://auth/callback (see MOBILE_OAUTH_REDIRECT_URI in oauthConfig.ts)
VITE_ACHPP_ID_SCOPE=*

# Realtime (Laravel Reverb / Pusher protocol)
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=pulse.test
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
