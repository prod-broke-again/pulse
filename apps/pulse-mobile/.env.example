# Public frontend variables only (Vite embeds these into build output).
# DO NOT put secrets here.

# API (production: https://pulse.appp-psy.ru)
VITE_API_BASE_URL=https://pulse.appp-psy.ru/api/v1
VITE_API_ORIGIN=https://pulse.appp-psy.ru
# Axios timeout ms (default 90000). SSO + slow IdP needs headroom.
# VITE_HTTP_TIMEOUT_MS=90000

# Auth: require Sanctum token for all routes except login/callback (default: on).
# Set to false only for local dev without API login.
# VITE_REQUIRE_AUTH=false

# ACHPP ID — public OAuth client (Passport) with PKCE; redirect URI must match IdP client
VITE_ACHPP_ID_BASE_URL=https://id.appp-psy.ru
VITE_ACHPP_ID_CLIENT_ID=c6000000-0000-4000-8000-000000000001
# Web prod: required on non-localhost. Native uses pulseapp:// (see oauthConfig.ts)
VITE_ACHPP_ID_REDIRECT_URI=https://pulse.appp-psy.ru/auth/callback
VITE_ACHPP_ID_SCOPE=*

# Realtime (Laravel Reverb / Pusher protocol)
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=pulse.appp-psy.ru
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
