APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# CORS: доп. origin'ы для browser fetch к /api/* и /api/widget/* (сайты с виджетом, без пробелов)
# CORS_ALLOWED_ORIGINS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=half_daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_HALF_DAILY_DAYS=3

# Pulse uses PostgreSQL 16+ (jsonb support). For Docker: DB_HOST=postgres
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pulse
DB_USERNAME=root
DB_PASSWORD=
# DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_COOKIE=pulse_appp_psy_session

# Broadcasting: use `reverb` only when the Reverb process is running (`php artisan reverb:start`).
# If Reverb is not running, server-side broadcast calls fail (e.g. cURL to localhost:8080). For local
# work without WebSockets, set BROADCAST_CONNECTION=null to disable broadcasting (Echo/realtime off).
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=pulse
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local
# For Docker: QUEUE_CONNECTION=redis, CACHE_STORE=redis
QUEUE_CONNECTION=redis
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Web chat widget: origins allowed for postMessage (parent → iframe). Comma-separated, no spaces.
# Include the Pulse app URL, sites with embedded widget, and optional www-variants, e.g.:
# WIDGET_ALLOWED_ORIGINS=https://pulse.appp-psy.ru,https://appp-psy.ru,https://www.appp-psy.ru,https://kukushechka.ru,https://www.kukushechka.ru
# WIDGET_ALLOWED_ORIGINS=${APP_URL}
# Global web widget kill-switch (overrides admin Web-виджет settings). Leave unset to use /admin.
# WIDGET_ENABLED=true
# Optional: override stub copy and channel links when set (non-empty)
# WIDGET_DISABLED_TITLE=
# WIDGET_DISABLED_TEXT=
# WIDGET_TELEGRAM_URL=
# WIDGET_VK_URL=
# WIDGET_MAX_URL=

# Social login for moderators (Filament /admin)
VKONTAKTE_CLIENT_ID=
VKONTAKTE_CLIENT_SECRET=
VKONTAKTE_REDIRECT_URI="${APP_URL}/auth/vk/callback"
TELEGRAM_BOT_NAME=
TELEGRAM_TOKEN=
TELEGRAM_REDIRECT_URI="${APP_URL}/auth/telegram/callback"

# FCM (Firebase Cloud Messaging) for push to desktop/mobile moderators (Ionic/Electron)
# FCM_SERVER_KEY=

# Web Push (VAPID) for browser push. Generate: php artisan web-push:vapid (or use Minishlink\WebPush\VAPID::createVapidKeys())
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# AI topic generation for chat list (timeweb | gptunnel)
AI_TOPIC_PROVIDER=timeweb
TIMEWEB_AI_API_KEY=
TIMEWEB_AI_BASE_URL=

GPTUNNEL_API_KEY=

# AI: auto-assign chat department from kickoff LLM (off by default). Confidence threshold 0.0–1.0.
FEATURE_AI_DEPARTMENT_ASSIGNMENT=false
FEATURE_AI_DEPT_CONFIDENCE=0.7

# ACHPP ID SSO (API: exchange IdP access token for local Sanctum token)
# PULSE_SSO_ONLY=true disables password /auth/login and Fortify registration + password reset UI routes
PULSE_SSO_ONLY=false
ACHPP_ID_BASE_URL=https://id.appp-psy.ru
# Optional internal URL for server-to-server calls from Pulse (local dev often uses http://id.test)
# ACHPP_ID_INTERNAL_URL=http://id.example.com
# Same public Passport client id as mobile (PKCE); required for POST /auth/sso/exchange with code
# Local IdP: php artisan db:seed --class=OAuthPulseMobileClientSeeder → c6000000-0000-4000-8000-000000000001
ACHPP_ID_CLIENT_ID=c6000000-0000-4000-8000-000000000001
# ACHPP_ID_PROFILE_PATH=/api/v1/user
# Local Laragon self-signed HTTPS to id.test: ACHPP_ID_VERIFY_SSL=false
# ACHPP_ID_VERIFY_SSL=true
# Laragon/Windows: cURL may stall on IPv6 for *.test → timeout 0 bytes; prefer IPv4:
# ACHPP_ID_FORCE_IPV4=true
# Pin hostname to loopback (include used ports): fixes 90s+ 0-byte profile timeouts
# ACHPP_ID_CURL_RESOLVE=id.test:80:127.0.0.1,id.test:443:127.0.0.1
# Outbound IdP HTTP total timeout (s); SSO can be slow locally (token + profile)
# ACHPP_ID_TIMEOUT=90
# ACHPP_ID_CONNECT_TIMEOUT=10

# Inbound webhooks from ACHPP ID (HMAC). Enable after shared secret is configured on both sides.
# PULSE_ID_WEBHOOKS_ENABLED=false
# PULSE_ID_WEBHOOK_SECRET=
# PULSE_ID_WEBHOOK_REPLAY_TOLERANCE=300

# VK community: outbound messages.send token (fallback if source has no settings.access_token); Callback API defaults
# VK_BOT_TOKEN=
# VK_GROUP_ID=
# VK_CALLBACK_SECRET=
# VK_CALLBACK_CONFIRMATION=
